# ----------------------------------------------------------------------------
# Shared runtime
# ----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
WS_URL=ws://localhost:4001
NEXT_PUBLIC_WS_URL=ws://localhost:4001/ws

# ----------------------------------------------------------------------------
# Supabase (public client)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# ----------------------------------------------------------------------------
# Supabase (server)
# ----------------------------------------------------------------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_JWT_SECRET=replace-me
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ----------------------------------------------------------------------------
# Server-only secrets
# ----------------------------------------------------------------------------
ADMIN_API_TOKEN=replace-me
INTERNAL_API_TOKEN=replace-me
CRON_SECRET=replace-me

# ----------------------------------------------------------------------------
# Workers / execution tuning
# ----------------------------------------------------------------------------
MATCHING_WORKER_POLL_INTERVAL_MS=1000
SETTLEMENT_INTERVAL_MS=10000
BASE_MIN_CONFIRMATIONS=3
BASE_RECON_MIN_CONFIRMATIONS=12

# ----------------------------------------------------------------------------
# Chain adapters (Base)
# ----------------------------------------------------------------------------
BASE_CHAIN_ID=8453
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://mainnet.base.org
BASE_EXPLORER_URL=https://basescan.org
BASE_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
BASE_USDC_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_BASE_EXPLORER_URL=https://basescan.org
NEXT_PUBLIC_BASE_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BASE_USDC_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BASE_SETTLEMENT_ASSET=USDC
CHAIN_ADAPTER_MODE=stub

# ----------------------------------------------------------------------------
# External APIs (read-only)
# ----------------------------------------------------------------------------
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLY_BUILDER_CODE=
POLYMARKET_ROUTED_TRADING_ENABLED=false
POLYMARKET_CLOB_SUBMITTER=disabled
NEXT_PUBLIC_BUILDER_MAKER_FEE_BPS=50
NEXT_PUBLIC_BUILDER_TAKER_FEE_BPS=100
NEXT_PUBLIC_BUILDER_FEE_STATUS=pending
BUILDER_MAKER_FEE_BPS=50
BUILDER_TAKER_FEE_BPS=100
BUILDER_FEE_STATUS=pending
KALSHI_API_URL=https://api.elections.kalshi.com

# ----------------------------------------------------------------------------
# Ambassador rewards / manual Polygon pUSD payout review
# ----------------------------------------------------------------------------
AMBASSADOR_REWARDS_ENABLED=false
AMBASSADOR_AUTO_CALCULATION_ENABLED=true
AMBASSADOR_AUTO_PAYOUT_REQUEST_ENABLED=false
AMBASSADOR_AUTO_PAYOUT_ENABLED=false
AMBASSADOR_MIN_PAYOUT_USDC_ATOMS=0
PAYOUT_CHAIN=polygon
PAYOUT_CHAIN_ID=137
PAYOUT_ASSET=pUSD
PAYOUT_ASSET_DECIMALS=6
POLYGON_EXPLORER_URL=https://polygonscan.com
POLYGON_PAYOUT_TREASURY_ADDRESS=placeholder
POLYGON_PUSD_ADDRESS=0xC011a7E12a19f7B1f670d46F03B03f3342E82DFB

