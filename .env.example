# ----------------------------------------------------------------------------
# Shared runtime
# ----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
WS_URL=ws://localhost:4001
NEXT_PUBLIC_WS_URL=ws://localhost:4001/ws

# ----------------------------------------------------------------------------
# Supabase (public client)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# ----------------------------------------------------------------------------
# Supabase (server)
# ----------------------------------------------------------------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_JWT_SECRET=replace-me
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ----------------------------------------------------------------------------
# Server-only secrets
# ----------------------------------------------------------------------------
ADMIN_API_TOKEN=replace-me
INTERNAL_API_TOKEN=replace-me
CRON_SECRET=replace-me

# ----------------------------------------------------------------------------
# Workers / execution tuning
# ----------------------------------------------------------------------------
MATCHING_WORKER_POLL_INTERVAL_MS=1000
SETTLEMENT_INTERVAL_MS=10000
BASE_MIN_CONFIRMATIONS=3
BASE_RECON_MIN_CONFIRMATIONS=12

# ----------------------------------------------------------------------------
# Chain adapters (Base)
# ----------------------------------------------------------------------------
BASE_CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org
BASE_WS_URL=wss://sepolia.base.org
BASE_EXPLORER_URL=https://sepolia-explorer.base.org
BASE_TREASURY_ADDRESS=0x00000000000000000000000000000000000000aa
BASE_USDC_ADDRESS=0x00000000000000000000000000000000000000bb
NEXT_PUBLIC_BASE_CHAIN_ID=84532
NEXT_PUBLIC_BASE_EXPLORER_URL=https://sepolia-explorer.base.org
NEXT_PUBLIC_BASE_TREASURY_ADDRESS=0x00000000000000000000000000000000000000aa
NEXT_PUBLIC_BASE_USDC_ADDRESS=0x00000000000000000000000000000000000000bb
NEXT_PUBLIC_BASE_SETTLEMENT_ASSET=USDC
SOLANA_RPC_URL=
CHAIN_ADAPTER_MODE=stub

# ----------------------------------------------------------------------------
# External APIs (read-only)
# ----------------------------------------------------------------------------
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
KALSHI_API_URL=https://api.elections.kalshi.com

# ----------------------------------------------------------------------------
# Optional local load test harness
# ----------------------------------------------------------------------------
LOAD_API_BASE_URL=http://127.0.0.1:4000
LOAD_WS_URL=ws://127.0.0.1:4001/ws
