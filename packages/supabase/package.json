{
  "name": "@bet/supabase",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/client/browser.d.ts",
      "default": "./dist/client/browser.js"
    },
    "./server": {
      "types": "./dist/client/server.d.ts",
      "default": "./dist/client/server.js"
    },
    "./admin": {
      "types": "./dist/client/admin.d.ts",
      "default": "./dist/client/admin.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json",
    "test": "pnpm exec node -e \"console.log('supabase: no tests yet')\""
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.56.0"
  }
}
