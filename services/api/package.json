{
  "name": "@bet/service-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "types": "src/server.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json",
    "test": "pnpm exec node --test --import tsx $(find src -name '*.test.ts' -print)",
    "test:db-happy-path": "node --import tsx src/scripts/db-happy-path.ts",
    "preflight:polymarket-public": "node --import tsx src/scripts/polymarket-public-live-preflight.ts"
  },
  "dependencies": {
    "@bet/chain": "workspace:*",
    "@bet/contracts": "workspace:*",
    "@bet/db": "workspace:*",
    "@bet/domain": "workspace:*",
    "@bet/integrations": "workspace:*",
    "@bet/ledger": "workspace:*",
    "@bet/matching": "workspace:*",
    "@bet/observability": "workspace:*",
    "@bet/supabase": "workspace:*",
    "@bet/trading": "workspace:*",
    "@polymarket/clob-client-v2": "^1.0.2",
    "ethers": "^6.14.4",
    "viem": "^2.46.3",
    "@bet/config": "workspace:*"
  }
}
