{
  "name": "@bet/external-sync-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import ./load-env.js --import tsx src/main.ts",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json",
    "test": "pnpm exec node --test --import tsx src/**/*.test.ts",
    "run": "node --import ./load-env.js --import tsx src/main.ts"
  },
  "dependencies": {
    "@bet/db": "workspace:*",
    "@bet/integrations": "workspace:*",
    "@bet/observability": "workspace:*",
    "dotenv": "^17.4.2"
  }
}
